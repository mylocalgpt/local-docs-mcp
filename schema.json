{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["repos"],
  "properties": {
    "$schema": { "type": "string" },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "paths", "alias"],
        "properties": {
          "url": { "type": "string", "description": "GitHub repo URL" },
          "paths": { "type": "array", "items": { "type": "string" }, "description": "Doc folder paths within the repo" },
          "alias": { "type": "string", "description": "Short name for this repo (must be unique)" }
        }
      }
    }
  }
}
