#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-push checks..."

if command -v golangci-lint &>/dev/null; then
  echo "=> golangci-lint"
  golangci-lint run ./...
else
  echo "=> golangci-lint (skipped: not installed)"
fi

echo "=> go vet"
go vet ./...

echo "=> go test"
go test ./...

echo "=> go build"
go build -o /dev/null ./cmd/local-docs-mcp

echo "All pre-push checks passed."
